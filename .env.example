# --- Core ---
ENV=dev
API_V1_PREFIX=/api/v1
# --- Postgres ---
POSTGRES_USER=dpb
POSTGRES_PASSWORD=dpb_pass
POSTGRES_DB=dpb
DATABASE_URL=postgresql+asyncpg://dpb:dpb_pass@postgres:5432/dpb
# --- Redis ---
REDIS_URL=redis://redis:6379/0
# --- Auth ---
JWT_SECRET=change-me-dev-secret
ACCESS_TTL=900
REFRESH_TTL=604800
RATE_LIMIT=100/minute
# --- ADK service ---
ADK_URL=http://adk-service:9000
ADK_SECRET=change-me-adk-secret
GOOGLE_API_KEY=REPLACE_ME_LATER
# --- Email (dev: mailhog) ---
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@demandplanner.local
APP_BASE_URL=http://localhost:3000
